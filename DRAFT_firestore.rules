rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // 3. Global Helpers
    function isSignedIn() { return request.auth != null; }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    function isAdmin() { 
      return isSignedIn() && 
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin'; 
    }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    // 4. User Profiles
    match /users/{userId} {
      function isValidUser(data) {
        return data.username is string && data.username.size() > 0 && data.username.size() <= 64 &&
               data.balance is number && data.balance >= 0 &&
               data.role in ['user', 'admin'] &&
               data.createdAt is timestamp;
      }

      allow get: if isOwner(userId) || isAdmin();
      allow list: if isAdmin();
      
      allow create: if isSignedIn() && isOwner(userId) && 
                      isValidId(userId) &&
                      isValidUser(incoming()) && 
                      incoming().role == 'user' && 
                      incoming().balance == 1000;

      allow update: if (
        isAdmin() || 
        (isOwner(userId) && isValidUser(incoming()) && (
          (incoming().diff(existing()).affectedKeys().hasOnly(['balance']))
        ))
      );
    }

    // 5. Bets
    match /bets/{betId} {
      function isValidBet(data) {
        return data.userId == request.auth.uid &&
               data.gameId is string &&
               data.amount is number && data.amount > 0 &&
               data.winAmount is number &&
               data.result in ['WIN', 'LOSS'] &&
               data.timestamp == request.time;
      }

      allow list: if isSignedIn() && (isAdmin() || resource.data.userId == request.auth.uid);
      allow get: if isSignedIn() && isValidId(betId) && (isAdmin() || resource.data.userId == request.auth.uid);
      allow create: if isSignedIn() && isValidId(betId) && isValidBet(incoming());
      allow update, delete: if isAdmin();
    }

    // 6. System Logs
    match /system_logs/{logId} {
      allow read, write: if isAdmin();
    }
  }
}
