rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // 3. Global Helpers
    function isSignedIn() { return request.auth != null; }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    function isAdmin() { 
      return isSignedIn() && 
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin'; 
    }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    // 4. User Profiles
    match /users/{userId} {
      function isValidUser(data) {
        return data.username is string && data.username.size() > 0 && data.username.size() <= 64 &&
               data.balance is number && data.balance >= 0 &&
               data.role in ['user', 'admin'] &&
               data.createdAt is timestamp;
      }

      allow get: if isOwner(userId) || isAdmin() || (userId.startsWith('guest_'));
      allow list: if isSignedIn() || isAdmin();
      
      allow create: if (isSignedIn() && isOwner(userId) && 
                      isValidId(userId) &&
                      isValidUser(incoming()) && 
                      (
                        (incoming().role == 'user' && incoming().username.lower() != 'admin') ||
                        (incoming().role == 'admin' && incoming().username.lower() == 'admin')
                      ) && 
                      incoming().balance == 10) ||
                      (userId.startsWith('guest_') && incoming().isGuest == true && incoming().balance == 10);

      allow update: if (
        isAdmin() || 
        (isOwner(userId) && (
          (incoming().diff(existing()).affectedKeys().hasOnly(['balance', 'isOnline', 'lastSeen', 'mustLose', 'isGuest'])) ||
          (existing().username.lower() == 'admin' && incoming().diff(existing()).affectedKeys().hasOnly(['role', 'balance', 'isOnline', 'lastSeen', 'mustLose', 'isGuest']))
        ))
      );
    }

    // 5. Game State
    match /game/state {
      allow read: if isSignedIn();
      allow update: if isAdmin();
      allow create: if isAdmin();
    }

    // 5.1 Global Settings
    match /settings/global {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // 6. Round Bets
    match /rounds/{roundId}/bets/{betId} {
      function isValidBet(data) {
        return data.userId == request.auth.uid &&
               data.username is string &&
               data.amount is number && data.amount > 0 &&
               data.chosenNumber is number &&
               data.roundId == roundId &&
               data.timestamp == request.time;
      }

      allow list, get: if isSignedIn();
      allow create: if isSignedIn() && isValidId(betId) && isValidBet(incoming());
      allow update, delete: if isAdmin();
    }

    // 7. Game History
    match /history/{historyId} {
      function isValidHistory(data) {
        return (data.userId == request.auth.uid || isAdmin()) &&
               data.username is string &&
               data.game is string &&
               data.result is number &&
               data.win is bool &&
               data.amount is number &&
               data.wonAmount is number &&
               data.timestamp == request.time;
      }

      allow list: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow get: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isSignedIn() && isValidHistory(incoming());
      allow update, delete: if isAdmin();
    }

    // 8. Old System Logs (Deny)
    match /system_logs/{logId} {
      allow read, write: if isAdmin();
    }

    // 9. IPL Betting
    match /ipl_questions/{questionId} {
      allow read: if isSignedIn();
      allow create, update, delete: if isAdmin();
    }

    match /ipl_bets/{betId} {
      function isValidIPLBet(data) {
        return data.userId == request.auth.uid &&
               data.status == 'pending' &&
               data.amount > 0 &&
               data.timestamp == request.time;
      }
      allow read: if isSignedIn() && (resource == null || resource.data.userId == request.auth.uid || isAdmin());
      allow list: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isSignedIn() && isValidIPLBet(incoming());
      allow update: if isAdmin(); // Admin settles bets
    }
  }
}
